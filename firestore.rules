rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Leads
    match /leads/{leadId} {
      allow read: if request.auth != null;
      allow write: if true; // Webhook precisa escrever
    }
    
    // Vendas
    match /sales/{saleId} {
      allow read: if request.auth != null;
      allow write: if true; // Webhook precisa escrever
    }
    
    // Contratos
    match /contracts/{contractId} {
      allow read: if request.auth != null;
      allow write: if true; // Webhook precisa escrever
    }
    
    // Carrinhos abandonados
    match /abandoned_carts/{cartId} {
      allow read: if request.auth != null;
      allow write: if true; // Webhook precisa escrever
    }
    
    // Clientes
    match /clients/{clientId} {
      allow read: if request.auth != null;
      allow write: if true; // Webhook precisa escrever
    }
    
    // Usuários
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if true; // Webhook precisa escrever
    }
    
    // Credenciais temporárias
    match /user_credentials/{credentialId} {
      allow read: if request.auth != null && request.auth.uid == credentialId;
      allow write: if true; // Webhook precisa escrever
    }
    
    // Erros do webhook
    match /webhook_errors/{errorId} {
      allow read: if false; // Apenas leitura interna
      allow write: if true; // Webhook precisa escrever
    }
    
    // Outras coleções existentes
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Treinos e Seções - Apenas admins podem escrever
    match /trainings/{trainingId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    match /training_sections/{sectionId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
  }
}
















