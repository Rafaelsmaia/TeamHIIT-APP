{
  "appId": "com.teamhiit.app",
  "appName": "TeamHIIT",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 3000,
      "launchAutoHide": true,
      "backgroundColor": "#3B82F6",
      "showSpinner": false,
      "spinnerColor": "#ffffff",
      "androidSplashResourceName": "splash",
      "androidScaleType": "CENTER_CROP"
    },
    "StatusBar": {
      "style": "dark"
    }
  }
}
